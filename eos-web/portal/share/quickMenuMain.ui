      <event name="beforeload">
        <script><![CDATA[
	
]]></script>
      </event>
      <event name="beforeSave">
        <script><![CDATA[
			for(var i=0;i<params.deletedRecords.length;i++){
				var delRecord=params.deletedRecords[i];
				for(var j=0;j<params.updatedRecords.length;j++){
					var up=params.updatedRecords[j];
					if(up.id==delRecord.id){
						params.updatedRecords.splice(j,1);
						break; 
					}
				}				
			}
			for(var i=0;i<params.updatedRecords.length;i++){
				var upRecord=params.updatedRecords[i];
				params.updatedRecords[i].menuName = upRecord.menuName.trim(); 
				if(upRecord.menuName==""){
					Ext.Msg.alert("提示信息","菜单名称不能为空，请输入！");
					return false;
				}	
			}
]]></script>
      </event>
      <event name="onSaveSuccess">
        <script><![CDATA[
 		var quickMenuWidget 
 		quickMenuWidget=Ext.getCmp("PORTALQUICKMENU");
 		if(quickMenuWidget==null)
 		quickMenuWidget=portalUtil.getWidget("quickMenu");
 		if(quickMenuWidget==null) return;
 		else
 		{
 		if(quickMenuWidget.refresh) quickMenuWidget.refresh();
 		else
 		quickMenuWidget.body.dom.innerHTML = "<div><iframe width='100%' height='100%' frameborder='0'  src='../widget/quickMenu.jsp?portalSkin="+portalSkin+ "'></iframe></div>"
 		}
		    		 		 
		    		 		
quickMenuWindow.close();]]></script>
      </event>
      <property name="entityType">com.primeton.portal.purview.entity.QuickMenu</property>
      <property name="root">dataList</property>
      <property name="url">com.primeton.portal.purview.service.QuickMenuManagerService.searchQuickMenuWithPage(com.primeton.widget.auth.User s:portal_user,com.primeton.portal.purview.service.PageCond pageCond).java</property>
      <property name="saveUrl">com.primeton.portal.purview.service.QuickMenuManagerService.save(com.primeton.portal.purview.entity.QuickMenu[] insertedRecords, com.primeton.portal.purview.entity.QuickMenu[] updatedRecords, com.primeton.portal.purview.entity.QuickMenu[] deletedRecords).java</property>
      <property name="addUrl"></property>
      <property name="updateUrl"></property>
      <property name="deleteUrl"></property>
      <property name="dataProvider">JavaBean</property>
    </dataSource>
  </dataContext>
  <widget id="quickMenuWindow" widgetType="window">
    <group name="items">
      <widget id="commongrid1" widgetType="commongrid">
        <group name="columns">
          <widget id="commongrid1_menuName" widgetType="column">
