            <property name="editor" value="Ext.form.TextField">
              <widget id="textfield4" widgetType="textfield">
                <property name="fieldLabel"></property>
                <property name="hideLabel">false</property>
                <property name="allowBlank">false</property>
                <property name="blankText">菜单名称不能为空</property>
                <property name="width">135</property>
                <property name="name">menuName</property>
              </widget>
            </property>
            <property name="hidden">false</property>
          </widget>
          <widget id="commongrid1_systemName" widgetType="column">
            <property name="width">153</property>
            <property name="header">所属应用</property>
            <property name="sortable">true</property>
            <property name="align">left</property>
            <property name="dataIndex">systemName</property>
            <property name="editor" value="Ext.form.TextField">
              <widget id="textfield1" widgetType="textfield">
                <property name="fieldLabel"></property>
                <property name="hideLabel">false</property>
                <property name="width">135</property>
                <property name="name">systemName</property>
              </widget>
            </property>
            <property name="hidden">false</property>
          </widget>
          <widget id="commongrid1_sort" widgetType="column">
            <property name="width">67</property>
            <property name="header">显示顺序</property>
            <property name="sortable">true</property>
            <property name="align">left</property>
            <property name="dataIndex">sort</property>
            <property name="editor" value="Ext.form.NumberField">
              <widget id="numberfield1" widgetType="numberfield">
                <property name="fieldLabel"></property>
                <property name="value"></property>
                <property name="emptyText">请输入数字...</property>
                <property name="hideLabel">false</property>
                <property name="width">135</property>
                <property name="name">sort</property>
              </widget>
            </property>
            <property name="hidden">false</property>
          </widget>
          <widget id="commongrid1_openMode" widgetType="column">
            <property name="width">142</property>
            <property name="header">打开方式</property>
            <property name="sortable">true</property>
            <property name="align">left</property>
            <property name="dataIndex">openMode</property>
            <property name="editor" value="Ext.form.ComboBox">
              <widget id="combo1" widgetType="combo">
                <property name="fieldLabel"></property>
                <property name="displayField"></property>
                <property name="valueField"></property>
                <property name="emptyText">请选择...</property>
                <property name="width">135</property>
                <property name="forceSelection">true</property>
                <property name="hideLabel">false</property>
                <property name="dataList">0:在新窗口中打开;1:在新tab页中打开;2:在同一tab页中打开;3:在新的或已有tab页中打开</property>
              </widget>
            </property>
            <property name="hidden">false</property>
          </widget>
        </group>
        <event name="beforeadd">
          <script><![CDATA[ Ext.Msg.alert("提示信息","请在功能树上使用右键菜单添加快捷菜单。");

return false;]]></script>
        </event>
        <property name="anchor">100% 100%</property>
