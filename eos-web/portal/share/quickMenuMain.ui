          <widget id="paging1" widgetType="paging">
            <property name="pageSize">10</property>
            <property name="displayMsg">显示 {0} - {1} 共 {2} 条</property>
            <property name="emptyMsg">没有数据</property>
            <property name="displayAddButton">true</property>
            <property name="displayDelButton">true</property>
            <property name="displaySaveButton">true</property>
          </widget>
        </property>
        <property name="footer">true</property>
        <property name="buttonAlign">center</property>
        <property name="height">211</property>
        <property name="autoLoadData">true</property>
        <property name="width">480</property>
      </widget>
    </group>
    <property name="layout">anchor</property>
