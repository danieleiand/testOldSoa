        </field>
        <field widgetType="datafield">
          <property name="name">roleName</property>
          <property name="type">string</property>
          <property name="mapping">roleName</property>
          <property name="sortType"></property>
          <property name="sortDir"></property>
          <property name="dateFormat"></property>
          <property name="defaultValue"></property>
          <property name="displayName">roleName</property>
          <property name="canbenull">true</property>
        </field>
