                <property name="name">radiogroup</property>
                <property name="checkValue">0</property>
              </widget>
            </group>
            <event name="change">
              <script><![CDATA[try{
if(newValue.getValue()==1)
{
button3.setDisabled(true);
button4.setDisabled(true);
button5.setDisabled(true);
button6.setDisabled(true);
}
else
{
button3.enable();
button4.enable();
button5.enable();
button6.enable();
}
}
catch(e)
{}
]]></script>
