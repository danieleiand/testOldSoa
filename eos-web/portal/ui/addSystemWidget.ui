<ui provider="primeton" displayName="Window" createTime="0" lastModified="0">
  <dataContext>
    <dataSource id="store1" type="servicestore">
      <group name="fields">
        <field widgetType="datafield">
          <property name="name">widgetName</property>
          <property name="type">string</property>
          <property name="mapping">widgetName</property>
          <property name="sortType"></property>
          <property name="sortDir"></property>
          <property name="dateFormat"></property>
          <property name="defaultValue"></property>
          <property name="displayName">可选widget</property>
          <property name="canbenull">true</property>
        </field>
        <field widgetType="datafield">
          <property name="name">catalog</property>
          <property name="type">int</property>
          <property name="mapping">catalog</property>
          <property name="sortType"></property>
          <property name="sortDir"></property>
          <property name="dateFormat"></property>
          <property name="defaultValue"></property>
          <property name="displayName">分类</property>
          <property name="canbenull">true</property>
        </field>
        <field widgetType="datafield">
          <property name="name">id</property>
          <property name="type">string</property>
          <property name="mapping">id</property>
          <property name="sortType"></property>
          <property name="sortDir"></property>
          <property name="dateFormat"></property>
          <property name="defaultValue"></property>
          <property name="displayName">id</property>
          <property name="canbenull">true</property>
        </field>
      </group>
      <event name="onLoadSuccess">
        <script><![CDATA[var viewPort = Ext.getCmp("portalTab").getActiveTab();
		var theme=viewPort.getId();
	var submitStr = "";
	var cols = viewPort.items.length;
		for (var i = 0; i < cols; i++) {
			var col = viewPort.items.itemAt(i);
			if (i != 0)
				submitStr = submitStr + ";";
			for (var j = 0; j < col.items.length; j++) {
				if (j != 0)
					submitStr = submitStr + ",";
				submitStr = submitStr + col.items.itemAt(j).portalid;
			}
		}

for(var i=0;i<records.length;i++)

{
var record=records[i];
if(submitStr.indexOf(record.get("id"))!=-1)
{
records.remove(record);
i--;
}

}]]></script> 
      </event>
      <property name="entityType">com.primeton.portal.purview.entity.Widget</property>
      <property name="root">dataList</property>
      <property name="url">com.primeton.widget.auth.AuthManager.getAllWidgets().java</property>
      <property name="saveUrl"></property>
      <property name="addUrl"></property>
      <property name="updateUrl"></property>
      <property name="deleteUrl"></property>
      <property name="dataProvider">JavaBean</property>
      <property name="autoLoad">true</property>
    </dataSource>
  </dataContext>
  <widget id="window2" widgetType="window">
    <group name="items">
      <widget id="commongrid1" widgetType="commongrid">
        <group name="columns">
          <widget id="commongrid1_widgetName" widgetType="column">
            <property name="width">262</property>
            <property name="header">可选widget</property>
            <property name="sortable">false</property>
            <property name="align">left</property>
            <property name="dataIndex">widgetName</property>
            <property name="editor" value="Ext.form.TextField">
              <widget id="textfield1" widgetType="textfield">
                <property name="fieldLabel"></property>
                <property name="hideLabel">false</property>
                <property name="width">135</property>
                <property name="name">widgetName</property>
              </widget>
            </property>
            <property name="hidden">false</property>
          </widget>
        </group>
        <property name="anchor">100% 100%</property>
        <property name="store">store1</property>
        <property name="title"></property>
        <property name="footer">true</property>
        <property name="buttonAlign">center</property>
        <property name="selModel" value="Ext.grid.CheckboxSelectionModel">
          <widget id="checkboxSelectionModel1" widgetType="checkboxSelectionModel"/>
        </property>
      </widget>
    </group>
    <group name="buttons">
      <widget id="button2" widgetType="button">
        <event name="click">
          <script><![CDATA[
 
 var viewPort = Ext.getCmp("portalTab").getActiveTab();
var submitStr = "";
var cols = viewPort.items.length;
	for (var i = 0; i < cols; i++) {
		var col = viewPort.items.itemAt(i);
		if (i != 0)
			submitStr = submitStr + ";";
		for (var j = 0; j < col.items.length; j++) {
			if (j != 0)
				submitStr = submitStr + ",";
			submitStr = submitStr + col.items.itemAt(j).portalid;
		}
	}
var userportal = submitStr;

var selectionModel = commongrid1.getSelectionModel();
var selected = selectionModel.getSelections();
var oneArrLength=userportal.split(";")[0].split(",").length;
if((oneArrLength+selected.length)>20){
	Ext.Msg.alert("提示信息","主题页内widget个数将大于20，请减少widget数量！");
	return;
}
if (selected.length == 0) {
	window2.close();
	return;
} else {
	for (var i = 0; i < selected.length; i++) {
		var item = selected[i];
		if(userportal.indexOf(item.get("id"))!=-1) continue;
		
	  var newPortlet=new Ext.ux.Portlet(
	  {
	   portalid:item.get("id"),
	   title:item.get("widgetName"),
	   height:200,tools :portalSysTools,
	   html:"允许删除<input type=checkbox >"
	      }
	
	  );
      viewPort.items.first().add(newPortlet);
	}
 viewPort.doLayout();
 window2.close();
 }
 


