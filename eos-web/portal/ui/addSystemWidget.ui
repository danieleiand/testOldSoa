]]></script>
        </event>
        <property name="text">添加</property>
      </widget>
      <widget id="button3" widgetType="button">
        <event name="click">
          <script><![CDATA[window2.close();]]></script>
        </event>
        <property name="text">取消</property>
      </widget>
    </group>
    <property name="layout">anchor</property>
    <property name="width">338</property>
    <property name="height">306</property>
    <property name="title">选择widgets</property>
    <property name="footer">true</property>
    <property name="modal">true</property>
    <property name="iconCls">widget-config</property>
  </widget>
  <hiddenWidgets name="hiddenWidgets"/>
