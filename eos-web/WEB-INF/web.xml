<?xml version="1.0" encoding="UTF-8"?>
<web-app id="defaultWebApp" version="2.4"
	xmlns="http://java.sun.com/xml/ns/j2ee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
	<display-name>abframe</display-name>
	
	<!--<distributable/> -->

	<filter>
		<filter-name>encode</filter-name>
		<filter-class>
			com.primeton.widget.filter.EncodeFilter
		</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>encode</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>
	<filter>
		<filter-name>checkVCode</filter-name>
		<filter-class>
			com.yd.soa.comm.utils.VerifyCodeFilter
		</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>checkVCode</filter-name>
		<url-pattern>*.login</url-pattern>
		<init-param>
			<param-name>vcode</param-name>
			<param-value>vCode</param-value>
		</init-param>
		<init-param>
			<param-name>loginPage</param-name>
			<param-value>/cas.login</param-value>
		</init-param>
	</filter-mapping>
	<filter>
		<filter-name>javaActionFilter</filter-name>
		<filter-class>
			com.primeton.ris.server.runtime.filter.javaActionFilter
		</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>javaActionFilter</filter-name>
		<url-pattern>*.java</url-pattern>
	</filter-mapping>

	<filter>
		<filter-name>gzip</filter-name>
		<filter-class>
			com.primeton.widget.filter.GZipFilter
		</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>gzip</filter-name>
		<url-pattern>*.gzip</url-pattern>
	</filter-mapping>
	
	<filter>
		<filter-name>otherCasUncheckFilter</filter-name>
		<filter-class>
			com.yd.soa.bpsclient.comm.OtherCasUncheckFilter
		</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>otherCasUncheckFilter</filter-name>
		<url-pattern>*.flow</url-pattern>
	</filter-mapping>
	<filter-mapping>
		<filter-name>otherCasUncheckFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
	</filter-mapping>
	
	
	
<!-- SSO Client Config Begin -->

	<filter>
			<filter-name>CAS Filter</filter-name>
			<filter-class>
				edu.yale.its.tp.cas.client.filter.CASFilter
			</filter-class>
			<init-param>
				<param-name>
					edu.yale.its.tp.cas.client.filter.loginUrl
				</param-name>
				<param-value>
					http://soa2.yundasys.com:8088/ydsoa/cas.login
				</param-value>
			</init-param>
			<init-param>
				<param-name>
					edu.yale.its.tp.cas.client.filter.validateUrl
				</param-name>
				<param-value>
					http://soa2.yundasys.com:8088/cas/serviceValidate
				</param-value>
			</init-param>
			<init-param>
				<param-name>
					edu.yale.its.tp.cas.client.filter.serverName
				</param-name>
				<param-value>soa2.yundasys.com:8088</param-value>
			</init-param>
			<init-param>
				<param-name>
					edu.yale.its.tp.cas.client.filter.initContextClass
				</param-name>
				<param-value>
					com.primeton.sso.abframe.adapter.InitContextAdapter
				</param-value>
			</init-param>
		</filter>
		<filter-mapping>
			<filter-name>CAS Filter</filter-name>
			<url-pattern>*.ui</url-pattern>
		</filter-mapping>
		<filter-mapping>
			<filter-name>CAS Filter</filter-name>
			<url-pattern>*.jsp</url-pattern>
		</filter-mapping>
		<filter-mapping>
			<filter-name>CAS Filter</filter-name>
			<url-pattern>*.wa</url-pattern>
		</filter-mapping>
	<filter-mapping>
			<filter-name>CAS Filter</filter-name>
			<url-pattern>*.flow</url-pattern>
		</filter-mapping>	
<servlet>
		<servlet-name>fileUploadServlet</servlet-name>
		<servlet-class>com.yd.soa.comm.utils.FileUploadSrvlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>fileUploadServlet</servlet-name>
		<url-pattern>/fileUpload.do</url-pattern>
	</servlet-mapping>
	<!--下载 begin-->
		<servlet>
			<servlet-name>downLoadServlet</servlet-name>
			<servlet-class>com.yd.soa.comm.FileDownloadServlet</servlet-class>
			<load-on-startup>1</load-on-startup>
		</servlet>
		<servlet-mapping>
			<servlet-name>downLoadServlet</servlet-name>
			<url-pattern>/down.servlet</url-pattern>
		</servlet-mapping>
		<servlet>
			<servlet-name>zipDownLoadServlet</servlet-name>
			<servlet-class>com.yd.soa.comm.FileDownloadZip</servlet-class>
			<load-on-startup>1</load-on-startup>
		</servlet>
		<servlet-mapping>
			<servlet-name>zipDownLoadServlet</servlet-name>
			<url-pattern>/zipdown.servlet</url-pattern>
		</servlet-mapping>
		<servlet>
			<servlet-name>zipsDownLoadServlet</servlet-name>
			<servlet-class>com.yd.soa.comm.FilesDownloadZip</servlet-class>
			<load-on-startup>1</load-on-startup>
		</servlet>
		<servlet-mapping>
			<servlet-name>zipsDownLoadServlet</servlet-name>
			<url-pattern>/zipsdown.servlet</url-pattern>
		</servlet-mapping>
		<!--下载 end-->
	<servlet>
		<servlet-name>CodeImg</servlet-name>
		<servlet-class>com.yd.soa.comm.utils.CodeImg</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>CodeImg</servlet-name>
		<url-pattern>/codeImage.cimg</url-pattern>
	</servlet-mapping>
<!-- SSO Client Config End -->

   <servlet>
		<servlet-name>FckConnector</servlet-name>
		<servlet-class>
			com.yd.soa.document.fckeditor.ConnectorServlet
		</servlet-class>
	</servlet>
		<servlet-mapping>
		<servlet-name>FckConnector</servlet-name>
		<url-pattern>/fckeditor/editor/filemanager/connectors/*</url-pattern>
	</servlet-mapping>
<!-- Portal Config With SSO Server Begin -->

		<servlet>
			<servlet-name>login</servlet-name>
			<servlet-class>
				com.primeton.widget.servlet.LoginServlet
			</servlet-class>
			<init-param>
				<param-name>login-url</param-name>
				<param-value>
					http://soa2.yundasys.com:8088/cas/login
				</param-value>
			</init-param>
			<init-param>
				<param-name>logout-url</param-name>
				<param-value>
					http://soa2.yundasys.com:8088/cas/logout
				</param-value>
			</init-param>
			<init-param>
				<param-name>cas-url</param-name>
				<param-value>http://soa2.yundasys.com:8088</param-value>
			</init-param>
			<init-param>
				<param-name>main-page</param-name>
				<param-value>
					http://soa2.yundasys.com:8088/ydsoa/portal/share/portal.ui		
				</param-value>
			</init-param>
		</servlet>
		<servlet-mapping>
			<servlet-name>login</servlet-name>
			<url-pattern>*.login</url-pattern>
		</servlet-mapping>


	<filter>
		<filter-name>uiAccessFilter</filter-name>
		<filter-class>
			com.primeton.ris.server.runtime.filter.UiFilter
		</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>uiAccessFilter</filter-name>
		<url-pattern>*.ui</url-pattern>
	</filter-mapping>

	<filter>
		<filter-name>uijsAccessFilter</filter-name>
		<filter-class>
			com.primeton.ris.server.runtime.filter.UijsFilter
		</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>uijsAccessFilter</filter-name>
		<url-pattern>*.uijs</url-pattern>
	</filter-mapping>


		<servlet>
			<servlet-name>Proxy</servlet-name>
			<servlet-class>
				<!--com.primeton.widget.proxy.HttpProxyServlet-->
				com.primeton.widget.servlet.WidgetServlet
			</servlet-class>
			<load-on-startup>1</load-on-startup>
		</servlet>
		<servlet-mapping>
			<servlet-name>Proxy</servlet-name>
			<url-pattern>/portalProxy/*</url-pattern>
		</servlet-mapping>

		<servlet>
			<servlet-name>WAProxy</servlet-name>
			<servlet-class>
				<!--com.primeton.widget.proxy.WAProxyServlet-->
				com.primeton.widget.servlet.WAProxyServlet
			</servlet-class>
		</servlet>
		<servlet-mapping>
			<servlet-name>WAProxy</servlet-name>
			<url-pattern>*.wa</url-pattern>
		</servlet-mapping>

		<servlet>
			<servlet-name>AjaxProxy</servlet-name>
			<servlet-class>
				com.primeton.widget.servlet.AjaxProxyServlet
			</servlet-class>
		</servlet>
		<servlet-mapping>
			<servlet-name>AjaxProxy</servlet-name>
			<url-pattern>*.ajaxProxyInvoke</url-pattern>
		</servlet-mapping>


		<filter>
			<filter-name>InterceptorFilter</filter-name>
			<filter-class>
				com.eos.access.http.InterceptorFilter
			</filter-class>
		</filter>
		<listener>
			<listener-class>
				com.primeton.sca.host.webapp.SCAWebServiceServletListener
			</listener-class>
		</listener>
		<listener>
			<listener-class>
				com.primeton.ext.runtime.core.RuntimeJ2EEHost
			</listener-class>
		</listener>
		<listener>
			<listener-class>
				com.primeton.engine.core.impl.process.SessionListener
			</listener-class>
		</listener>
		<listener>
			<listener-class>
				com.eos.access.http.UserObjectSessionListener
			</listener-class>
		</listener>


		<filter-mapping>
			<filter-name>InterceptorFilter</filter-name>
			<url-pattern>/*</url-pattern>
			<dispatcher>FORWARD</dispatcher>
			<dispatcher>REQUEST</dispatcher>
			<dispatcher>INCLUDE</dispatcher>
		</filter-mapping>

		<servlet>
			<servlet-name>AxisServlet</servlet-name>
			<servlet-class>
				org.apache.axis2.transport.http.AxisServlet
			</servlet-class>
			<load-on-startup>1</load-on-startup>
		</servlet>

		<servlet-mapping>
			<servlet-name>AxisServlet</servlet-name>
			<url-pattern>*.jws</url-pattern>
		</servlet-mapping>

		<servlet-mapping>
			<servlet-name>AxisServlet</servlet-name>
			<url-pattern>/services/*</url-pattern>
		</servlet-mapping>

		<session-config>
			<session-timeout>30</session-timeout>
		</session-config>
		<welcome-file-list>
			<welcome-file>index.jsp</welcome-file>
		</welcome-file-list>

		<mime-mapping>
			<extension>xml</extension>
			<mime-type>application/xml</mime-type>
		</mime-mapping>
		<mime-mapping>
			<extension>war</extension>
			<mime-type>application/zip</mime-type>
		</mime-mapping>
		<mime-mapping>
			<extension>ear</extension>
			<mime-type>application/zip</mime-type>
		</mime-mapping>
		<mime-mapping>
			<extension>zip</extension>
			<mime-type>application/zip</mime-type>
		</mime-mapping>
		<error-page>
			<error-code>404</error-code>
			<location>/common/notFound.jsp</location>
		</error-page>
		<error-page>
			<error-code>500</error-code>
			<location>/common/runError.jsp</location>
		</error-page>
		
			<jsp-config>
			<jsp-property-group>
			<url-pattern>*.jsp</url-pattern>
			<page-encoding>UTF-8</page-encoding>
			</jsp-property-group>
			</jsp-config>
		
</web-app>