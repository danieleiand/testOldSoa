<sqlMap>
    <select id="org_id" parameterClass="java.lang.String" resultClass="java.util.HashMap">
       select ORGID FROM OM_ORGANIZATION WHERE ORGCODE = #bianma#
       </select>
    <select id="parent_org_id" parameterClass="java.lang.String" resultClass="java.util.HashMap">
       select PARENTORGID FROM OM_ORGANIZATION WHERE ORGCODE = #bianma#
       </select>
</sqlMap>