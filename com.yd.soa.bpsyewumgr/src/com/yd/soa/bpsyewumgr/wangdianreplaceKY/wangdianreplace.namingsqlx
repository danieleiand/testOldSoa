        <result column="GSPHONE" javaType="string" property="gsphone"/>
        <result column="FBNAME" javaType="string" property="fbname"/>
        <result column="FBFZR" javaType="string" property="fbfzr"/>
        <result column="FBADDRESS" javaType="string" property="fbaddress"/>
        <result column="FBYB" javaType="string" property="fbyb"/>
