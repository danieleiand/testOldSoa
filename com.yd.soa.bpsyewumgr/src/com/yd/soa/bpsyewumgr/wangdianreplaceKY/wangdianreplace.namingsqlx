        <result column="FBCHAXUN" javaType="string" property="fbchaxun"/>
        <result column="FBTOUSU" javaType="string" property="fbtousu"/>
        <result column="FBCHUANZHEN" javaType="string" property="fbchuanzhen"/>
        <result column="FBZZNAME" javaType="string" property="fbzzname"/>
        <result column="FBZCADDR" javaType="string" property="fbzcaddr"/>
        <result column="FBZZH" javaType="string" property="fbzzh"/>

        <result column="SXCZZF" javaType="string" property="sxczzf"/>
        <result column="SXXZZF" javaType="string" property="sxxzzf"/>
        <result column="SXDZZF" javaType="string" property="sxdzzf"/>
        <result column="GZFSHULIANG" javaType="string" property="gzfshuliang"/>
        <result column="YGRENSHU" javaType="string" property="ygrenshu"/>
        <result column="KDSGZZG" javaType="string" property="kdsgzzg"/>
        <result column="SCZD" javaType="string" property="sczd"/>
        <result column="RZJL" javaType="string" property="rzjl"/>
