         <select id="query_wangdian2_filter" parameterClass="java.util.Map" remapResults="true"  resultMap="query_wangdian2">
           SELECT * FROM (
SELECT  AI.APPLYNO,
           AI.PROCESSINSTID,
           AI.APPLER,
           AI.APPLERID,
            to_char(AI.APPDATE,'yyyy-MM-dd hh24:mi:ss') as APPDATE,
           AI.APPPOST,
           AI.DEPARTMENT,
           AI.DEPARTMENTID,
           AI.FILLMAN,
           AI.FILLMANID,
           AI.CONDITION,
           AI.PROCESSDEFNAME,
           AI.APPLYUNIT,
           H.TOPICPRODEFCHNAME,
           H.APPCATE,
           to_char(AI.CREATETIME,'yyyy-MM-dd hh24:mi:ss') as CREATETIME,
           to_char(AI.UPDATETIME,'yyyy-MM-dd hh24:mi:ss') as UPDATETIME,
           NULL AS APPCATENAME,
           NULL AS CONDITIONNAME,  
           
           Y.TELL,
           to_char(Y.KTDATE,'yyyy-MM-dd')as KTDATE,
           Y.XKSCKTYPE,
           NULL AS XKSCKTYPENAME,
           Y.GSNAME,
           Y.GSFZR,
           Y.GSADDRESS,
           Y.GSYB,
           Y.GSTELL,
           Y.GSPHONE,
           Y.FBNAME,
           Y.FBFZR,
           Y.FBADDRESS,
           Y.FBYB,
           Y.FBDH,
           Y.FBPHONE,
           Y.RZJL,
           Y.XYYSCL,
           Y.XYSMQ,
           Y.XYYG,
           Y.XYYYMJ,
           Y.XYBGDN,
           Y.XYDZC,
           Y.XYZZF,
           Y.PSFW,
           Y.NOPSFW,
           Y.CHUANGKOUDAIMA,
           Y.JIEDAO,
           Y.JIEDAOFB, 
           Y.SXYSCL,
           Y.SXYG,
           Y.SXSMQ,
           Y.SXDD,
           Y.SXDZC,
           Y.SXCZZF,
           Y.SXXZZF,
           Y.SXDZZF,
           Y.SCZD,
           Y.YGRENSHU,
           Y.GZFSHULIANG,
           Y.GENGHUANTYPE,
           NULL AS GENGHUANTYPENAME,
           Y.KDSGZZG,
            Y.BAOXIANRENSHU,
            
            Y.GSZZNAME,
           Y.GSZCADDR,
           Y.GSZZH,
           Y.GSSWH,
           Y.FBZZNAME,
           Y.FBZCADDR,
           Y.FBZZH,
           Y.FBSWH,
            
            Y.CHUANGKOUWEIHU,
            NULL AS CHUANGKOUWEIHUNAME,
            Y.BIANMA,
            Y.XINGZHENGQUYUJIEDAO,
            Y.AAAA,
            Y.XINGZHENGQUYU,
            Y.TAOBAO,
            NULL AS TAOBAONAME,
           Y.SQCKLX,
           NULL AS SQCKLXNAME,
           J.NAME,
           J.DAIMA,
           J.CKTYPE,
           NULL AS CKTYPENAME,
           J.WAIGUAN,
           NULL AS WAIGUANNAME,
           J.GGP,
           NULL AS GGPNAME,
           J.CZQ,
           NULL AS CZQNAME,
           J.KFQ,
           NULL AS KFQNAME,
           J.ZBZT,
           NULL AS ZBZTNAME,
           J.QTBZ,
           J.COLOR,
           NULL AS COLORNAME,
           J.LOGO,
           NULL AS LOGONAME,
           J.CQTBZ,
           J.XUAHO,
           J.NEWCKNAME,
           J.NEWCKDAIMA,
           yd_bps_wfactivity(AI.PROCESSINSTID) AS WFACTIVITYS
    
         
      FROM YD_YW_WANGDIAN Y left join YD_YW_JINDU J on Y.PROCESSINSTID = J.PROCESSINSTID ,
       YD_BPS_HLEPTOPIC H,OM_ORGANIZATION O,OA_APPLYINFO AI
     WHERE AI.PROCESSDEFNAME='com.yd.soa.bpsyewumgr.wangdian.wangdian'
       AND AI.PROCESSDEFNAME = H.TOPICPRODEFNAME
       AND AI.APPLYNO=Y.APPNO
       AND AI.IFDELETED = 0
       AND AI.DEPARTMENTID = O.ORGID
		 	  <isNotNull prepend="AND" property="filterid">
		          <![CDATA[EXISTS(SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 0
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND F.SCOPETYPEID = AI.APPLERID
        UNION
        SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 3
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND F.SCOPETYPEID=3
        UNION
        SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 2
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND INSTR(O.ORGSEQ,'.'||F.SCOPETYPEID||'.')>0
       )]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="applyunit">
		          <![CDATA[INSTR(AI.APPLYUNIT,#applyunit#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="department">
		          <![CDATA[INSTR(AI.DEPARTMENT,#department#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="appler">
		          <![CDATA[INSTR(AI.APPLER,#appler#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="fillman">
		          <![CDATA[INSTR(AI.FILLMAN,#fillman#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="applerid">
		          AI.APPLERID ='$applerid$'
		      </isNotNull>
		 	  <isNotNull prepend="AND" property="processinstid">
		          AI.PROCESSINSTID = #processinstid#
		      </isNotNull>
		      
		      <isNotNull prepend="AND" property="startappdate">
		          <![CDATA[AI.APPDATE >= to_date('$startappdate$ 00:00:00', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="endappdate">
		      	  <![CDATA[AI.APPDATE < to_date('$endappdate$ 23:59:59', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      
		       <isNotNull prepend="AND" property="startupdatetime">
		          <![CDATA[AI.UPDATETIME >= to_date('$startupdatetime$ 00:00:00', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="endupdatetime">
		      	  <![CDATA[AI.UPDATETIME < to_date('$endupdatetime$ 23:59:59', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="condition">
		          AI.CONDITION = #condition#
		      </isNotNull> 
		       <isNotNull prepend="AND" property="chuangkouweihu">
		          Y.chuangkouweihu = #chuangkouweihu#
		      </isNotNull>
		      <isNotNull prepend="AND" property="sqcklx">
		          Y.sqcklx = #sqcklx#
		      </isNotNull>
		      <isNotNull prepend="AND" property="xkscktype">
		          Y.xkscktype = #xkscktype#
		      </isNotNull>
		      <isNotNull prepend="AND" property="bianma">
		          Y.bianma = #bianma#
		      </isNotNull>
		      <isNotNull prepend="AND" property="genghuantype">
		          Y.genghuantype = #genghuantype#
		      </isNotNull>
		      <isNotNull prepend="AND" property="aaaa">
		          Y.aaaa = #aaaa#
		      </isNotNull>) S
		      WHERE 1=1
		      <isNotNull prepend="AND" property="wfactivitys">
		          S.WFACTIVITYS like '%'||#wfactivitys#||'%'
		      </isNotNull>
		     order by S.UPDATETIME desc
     </select>
     <resultMap class="commonj.sdo.DataObject" id="amount_province_result">
        <result column="PID" javaType="long" property="pid"/>
        <result column="PNAME" javaType="string" property="pname"/>
        <result column="amount" javaType="long" property="amount"/>
     </resultMap>
     
     <select id="amount_province" parameterClass="java.util.Map" resultMap="amount_province_result">    
     select pid,pname,count (pinst) amount  from 
	(select p.provinceid  pid , p.provincename pname, y.processinstid pinst
	from  province p , yd_yw_wangdian y,OA_APPLYINFO AI
	 where  (substr(y.gsaddress,0,instr(y.gsaddress,',')-1) =p.provincename) and y.chuangkouweihu in ('C','1') and y.xkscktype in ('1','2')  and  ai.processinstid = y.processinstid and  ai.condition='4'
	  	<isNotNull prepend="AND" property="startappdate">
		          <![CDATA[AI.APPDATE >= to_date('$startappdate$ 00:00:00', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="endappdate">
		      	  <![CDATA[AI.APPDATE < to_date('$endappdate$ 23:59:59', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
	  	
	
	) group by pid,pname order by pid
		
     </select>
     
      <update id="updateChuangkouWangdian"  parameterClass="java.util.HashMap">

     	update yd_yw_wangdian t set t.chuangkoudaima = #aaaa#,t.bianma = #aaaa# where t.processinstid = #processinstid#
     	
     </update>
      <update id="updateChuangkouFenbu"  parameterClass="java.util.HashMap">

     	update yd_yw_wangdian t set t.chuangkoudaima = #aaaa#,t.aaaa = #aaaa# where t.processinstid = #processinstid#
     	
     </update>
       <update id="updateSap"  parameterClass="java.util.HashMap">

     	update yd_yw_wangdian t set t.saperror = #saperror#,t.sapkunnr= #sapkunnr#,t.sapmsage=#sapmsage# where t.processinstid = #processinstid#
     	
     </update>
     
     <update id="updateShenpi"  parameterClass="java.util.HashMap">

     	update yd_yw_wangdian t set t.shenpi = #shenpi# where t.processinstid = #processinstid#
     	
     </update>
     
     
     
     <!-- 查询网点详情 -->
           <select id="queryWd" parameterClass="java.util.HashMap"  resultClass="commonj.sdo.DataObject"  remapResults="true">
			SELECT
							A . ID,
							A .BIANMA,
							A .GSNAME,
							A .GSADDRESS,
							A .GSFZR,
							A .GSPHONE,
							A .ID_CARD_NO,
							A .GENDER,
							A .NATION,
							A .ID_CARD_NODR,
							OMA.WSTATUS,
							A .GSZZNAME,
							A .GSZZH,
							WF.ENDTIME,
							TRUNC ( MONTHS_BETWEEN (SYSDATE, WF.ENDTIME) / 12, 0 ) AS AT_YEAR,
							OMA.REMARK
FROM
								  YD_YW_WANGDIAN A
			LEFT JOIN    WFWORKITEM WF ON WF.PROCESSINSTID = A .PROCESSINSTID AND WF.CURRENTSTATE = 12 AND WF.ACTIVITYDEFID = 'end'
			LEFT JOIN    OM_ORGNIZATION_APPEND OMA ON OMA.WNAME = A .GSNAME
WHERE
				1 = 1
					 <isNotNull prepend="and" property="ID">
	  		  	           A.ID = #ID#
	  				</isNotNull>
					 <isNotNull prepend="and" property="provincename">
	  		  	           A.PROVINCEID = #provincename#
	  				</isNotNull>
					 <isNotNull prepend="and" property="cityname">
	  		  	           A.CITYID = #cityname#
	  				</isNotNull>
					 <isNotNull prepend="and" property="WSTATUS">
	  		  	          OMA.WSTATUS = #WSTATUS#
	  				</isNotNull>
					 <isNotNull prepend="and" property="WCODE">
	  		  	           A.BIANMA = #WCODE#
	  				</isNotNull>
					 <isNotNull prepend="and" property="WNAME">
	  		  	           A.GSNAME = #WNAME#
	  				</isNotNull>
	  	  AND A.XKSCKTYPE=3
    </select>
 
    
    
     <!-- 更改网点备注 -->
     <update id="updateWdREMARK"  parameterClass="java.util.HashMap"   >
           update OM_ORGNIZATION_APPEND OMA SET OMA.REMARK=#REMARK# WHERE  OMA.WNAME = #GSNAME#
      </update>
      
     <!-- 更改网点审批时间 -->
     <update id="updateWDEndTime"  parameterClass="java.util.HashMap"   >
           update WFWORKITEM  WF set WF.ENDTIME = TO_DATE(to_char(TO_DATE(#ENDTIME#,'yyyy-mm-dd hh24:mi:ss'),'yyyy-mm-dd hh24:mi:ss'),'yyyy-mm-dd hh24:mi:ss')
            WHERE WF.PROCESSINSTID = #PROCESSINSTID# AND WF.CURRENTSTATE = 12 AND WF.ACTIVITYDEFID = 'end'
      </update>
      
        <!-- 查询历史数据-->
      <select id="queryHistory" parameterClass="java.util.HashMap"  resultClass="commonj.sdo.DataObject"  remapResults="true">
      		SELECT
					        A . ID,
							A .BIANMA,
							A .GSNAME,
							A .GSFZR,
							A .GSPHONE,
							A .ID_CARD_NO,
							A .GENDER,
							A .NATION,
							A .ID_CARD_NODR,
							A.WSTATUS,
							A .GSZZNAME,
							A .GSZZH,
							A.ENDTIME,
							A. AT_YEAR,
							A.REMARK
		 FROM					
					 YD_YW_WANGDIANHIS A
					
				 WHERE 1=1
				 	 <isNotNull prepend="and" property="BIANMA">
	  		  	           A.BIANMA= #BIANMA#
	  				</isNotNull>
	  				order By A.UPDATETIME  desc
      </select>
      
      
      <select id="queryYwWd" parameterClass="java.util.HashMap"  resultClass="commonj.sdo.DataObject"  remapResults="true">
      SELECT
					A.ID
		FROM
					YD_YW_WANGDIAN A 			
		WHERE 
					A.BIANMA =#BIANMA#
					
        </select>
</sqlMap>