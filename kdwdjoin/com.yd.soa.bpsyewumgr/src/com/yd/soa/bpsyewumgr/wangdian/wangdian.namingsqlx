    <select id="query_wangdian_filelist_filter" parameterClass="java.util.Map" resultClass="commonj.sdo.DataObject">
    	SELECT distinct AI.PROCESSINSTID,
		        AI.RELATIONID,    
		        AF.FILE_ID,
		        AF.FILE_NAME,AI.CREATETIME
		      FROM ((YD_YW_WANGDIAN Y left join YD_YW_JINDU J on Y.PROCESSINSTID = J.PROCESSINSTID )left join OA_APPROVALINFO AP on ap.processinstid = y.processinstid and ap.activitydefid = 'YD_ZB_XXZXQXGLY')left join OA_APPROVALINFO FO ON FO.ACTIVITYDEFID = 'end'and y.processinstid = fo.processinstid,
		      YD_YW_BAOXIAN B, YD_BPS_HLEPTOPIC H,OM_ORGANIZATION O,OA_APPLYINFO AI
		      left join AT_FILEUPLOAD AF ON AF.RELATION_ID = AI.RELATIONID 
		     WHERE AI.PROCESSDEFNAME='com.yd.soa.bpsyewumgr.wangdian.wangdian'
		       AND AI.PROCESSDEFNAME = H.TOPICPRODEFNAME
		       AND AI.APPLYNO=Y.APPNO
		       AND AI.IFDELETED = 0
		       AND TO_NUMBER(AI.DEPARTMENTID)=O.ORGID
		       AND Y.ID = B.UXHID
		        <isNotNull prepend="AND" property="filterid">
		          <![CDATA[EXISTS(SELECT 1
				          FROM YD_CF_FILTER F
				         WHERE F.FILTERTYPE = 1
				           AND F.IFDELETED = 0
				           AND F.OPID = #filterid#
				           AND F.SCOPETYPE = 0
				           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
				           AND F.SCOPETYPEID = AI.APPLERID
				        UNION
				        SELECT 1
				          FROM YD_CF_FILTER F
				         WHERE F.FILTERTYPE = 1
				           AND F.IFDELETED = 0
				           AND F.OPID = #filterid#
				           AND F.SCOPETYPE = 3
				           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
				           AND F.SCOPETYPEID=3
				        UNION
				        SELECT 1
				          FROM YD_CF_FILTER F
				         WHERE F.FILTERTYPE = 1
				           AND F.IFDELETED = 0
				           AND F.OPID = #filterid#
				           AND F.SCOPETYPE = 2
				           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
				           AND INSTR(O.ORGSEQ,'.'||F.SCOPETYPEID||'.')>0
				     )]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="applyunit">
		          <![CDATA[INSTR(AI.APPLYUNIT,#applyunit#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="department">
		          <![CDATA[INSTR(AI.DEPARTMENT,#department#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="appler">
		          <![CDATA[INSTR(AI.APPLER,#appler#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="fillman">
		          <![CDATA[INSTR(AI.FILLMAN,#fillman#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="applerid">
		          AI.APPLERID ='$applerid$'
		      </isNotNull>
		 	  <isNotNull prepend="AND" property="processinstid">
		          AI.PROCESSINSTID = #processinstid#
		      </isNotNull>
		      
		      <isNotNull prepend="AND" property="startappdate">
		          <![CDATA[AI.APPDATE >= to_date('$startappdate$ 00:00:00', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="endappdate">
		      	  <![CDATA[AI.APPDATE < to_date('$endappdate$ 23:59:59', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="condition">
		          AI.CONDITION = #condition#
		      </isNotNull> 
		     ORDER BY AI.CREATETIME DESC
    </select>
    <select id="query_wangdian_filter" parameterClass="java.util.Map" remapResults="true"  resultMap="query_wangdian">
    SELECT * FROM (
     SELECT AI.APPLYNO,
           AI.PROCESSINSTID,
           AI.APPLER,
           AI.APPLERID,
            to_char(AI.APPDATE,'yyyy-MM-dd hh24:mi:ss') as APPDATE,
           AI.APPPOST,
           AI.DEPARTMENT,
           AI.DEPARTMENTID,
           AI.FILLMAN,
           AI.FILLMANID,
           AI.CONDITION,
           AI.PROCESSDEFNAME,
           AI.APPLYUNIT,
           H.TOPICPRODEFCHNAME,
           H.APPCATE,
           to_char(AI.CREATETIME,'yyyy-MM-dd hh24:mi:ss') as CREATETIME,
            to_char(AI.UPDATETIME,'yyyy-MM-dd hh24:mi:ss') as UPDATETIME,
           NULL AS APPCATENAME,
           NULL AS CONDITIONNAME,  
           
           Y.TELL,
           to_char(Y.KTDATE,'yyyy-MM-dd')as KTDATE,
           Y.XKSCKTYPE,
           NULL AS XKSCKTYPENAME,
           Y.GSNAME,
           Y.GSFZR,
           Y.GSADDRESS,
           Y.GSYB,
           Y.GSTELL,
           Y.GSPHONE,
           Y.FBNAME,
           Y.FBFZR,
           Y.FBADDRESS,
           Y.FBYB,
           Y.FBDH,
           Y.FBPHONE,
           Y.RZJL,
           Y.XYYSCL,
           Y.XYSMQ,
           Y.XYYG,
           Y.XYYYMJ,
           Y.XYBGDN,
           Y.XYDZC,
           Y.XYZZF,
           Y.PSFW,
           Y.CHUANGKOUDAIMA,
           Y.JIEDAO,
           Y.JIEDAOFB, 
           Y.SXYSCL,
           Y.SXYG,
           Y.SXSMQ,
           Y.SXDD,
           Y.SXDZC,
           Y.SXCZZF,
           Y.SXXZZF,
           Y.SXDZZF,
           Y.SCZD,
           Y.YGRENSHU,
           Y.GZFSHULIANG,
           Y.GENGHUANTYPE,
           NULL AS GENGHUANTYPENAME,
           Y.KDSGZZG,
       	   Y.BAOXIANRENSHU,
       	   
       	   Y.CHUANGKOUWEIHU,
       	   NULL AS CHUANGKOUWEIHUNAME,
       	   Y.BIANMA,
       	   Y.XINGZHENGQUYUJIEDAO,
       	   Y.AAAA,
       	   Y.XINGZHENGQUYU,
       	   Y.TAOBAO,
       	   NULL AS TAOBAONAME,
       	   
       	   Y.SQCKLX,
           NULL AS SQCKLXNAME,
           
           Y.GSZZNAME,
           Y.GSZCADDR,
           Y.GSZZH,
           Y.GSSWH,
           Y.FBZZNAME,
           Y.FBZCADDR,
           Y.FBZZH,
           Y.FBSWH,
           
           J.NAME,
           J.DAIMA,
           J.CKTYPE,
           NULL AS CKTYPENAME,
           J.WAIGUAN,
           NULL AS WAIGUANNAME,
           J.GGP,
           NULL AS GGPNAME,
           J.CZQ,
           NULL AS CZQNAME,
           J.KFQ,
           NULL AS KFQNAME,
           J.ZBZT,
           NULL AS ZBZTNAME,
           J.QTBZ,
           J.COLOR,
           NULL AS COLORNAME,
           J.LOGO,
           NULL AS LOGONAME,
           J.CQTBZ,
           J.XUAHO,
           J.NEWCKNAME,
           J.NEWCKDAIMA,
           
           B.XUHAO,
           B.UNAME,
           B.SEX,
           NULL AS SEXNAME,
           B.SFZ,
         
      	   to_char(AP.APPROVEDATE,'yyyy-MM-dd hh24:mi:ss') as xinxiapprovedate,
           to_char(FO.APPROVEDATE,'yyyy-MM-dd hh24:mi:ss') as fafangapprovedate,
           to_char(
					(select max(wf.endtime) from wfworkitem wf, YD_YW_WANGDIAN wd
                                  where wf.processinstid = wd.processinstid
                                    and wf.activitydefid = 'YD_ZB_ZLWH'
                                    and wf.currentstate = '12'
                                    and wf.processinstid = ai.processinstid),'yyyy-MM-dd hh24:mi:ss')  as GDENDTIME,
          yd_bps_wfactivity(AI.PROCESSINSTID) AS WFACTIVITYS
      FROM ((YD_YW_WANGDIAN Y left join YD_YW_JINDU J on Y.PROCESSINSTID = J.PROCESSINSTID )left join OA_APPROVALINFO AP on ap.processinstid = y.processinstid and ap.activitydefid = 'YD_ZB_XXZXQXGLY')
      left join OA_APPROVALINFO FO ON FO.ACTIVITYDEFID = 'end'and y.processinstid = fo.processinstid left join 
  YD_YW_BAOXIAN B on y.id = b.UXHID, YD_BPS_HLEPTOPIC H,OM_ORGANIZATION O,OA_APPLYINFO AI
     WHERE AI.PROCESSDEFNAME='com.yd.soa.bpsyewumgr.wangdian.wangdian'
       AND AI.PROCESSDEFNAME = H.TOPICPRODEFNAME
       AND AI.APPLYNO=Y.APPNO
       AND AI.IFDELETED = 0
       AND AI.DEPARTMENTID = O.ORGID
       
        
		 	 <isNotNull prepend="AND" property="filterid">
		          <![CDATA[EXISTS(SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 0
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND F.SCOPETYPEID = AI.APPLERID
        UNION
        SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 3
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND F.SCOPETYPEID=3
        UNION
        SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 2
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND INSTR(O.ORGSEQ,'.'||F.SCOPETYPEID||'.')>0
       )]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="applyunit">
		          <![CDATA[INSTR(AI.APPLYUNIT,#applyunit#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="department">
		          <![CDATA[INSTR(AI.DEPARTMENT,#department#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="appler">
		          <![CDATA[INSTR(AI.APPLER,#appler#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="fillman">
		          <![CDATA[INSTR(AI.FILLMAN,#fillman#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="applerid">
		          AI.APPLERID ='$applerid$'
		      </isNotNull>
		 	  <isNotNull prepend="AND" property="processinstid">
		          AI.PROCESSINSTID = #processinstid#
		      </isNotNull>
		      
		      <isNotNull prepend="AND" property="startappdate">
		          <![CDATA[AI.APPDATE >= to_date('$startappdate$ 00:00:00', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="endappdate">
		      	  <![CDATA[AI.APPDATE < to_date('$endappdate$ 23:59:59', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      
		       <isNotNull prepend="AND" property="startupdatetime">
		          <![CDATA[AI.UPDATETIME >= to_date('$startupdatetime$ 00:00:00', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="endupdatetime">
		      	  <![CDATA[AI.UPDATETIME < to_date('$endupdatetime$ 23:59:59', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      
		      <isNotNull prepend="AND" property="condition">
		          AI.CONDITION = #condition#
		      </isNotNull> ) S
		     order by S.UPDATETIME desc
     </select>
