	<select id="query_gcsqexcel_filter" parameterClass="java.util.Map" resultMap="query_gcsqexcel">
	SELECT * FROM (
	SELECT AI.APPLYNO,
       AI.PROCESSINSTID,
       AI.APPLER,
       AI.APPLERID,
       to_char(AI.APPDATE,'yyyy-MM-dd hh24:mi:ss') as APPDATE,
       AI.APPPOST,
       AI.DEPARTMENT,
       AI.DEPARTMENTID,
       AI.FILLMAN,
       AI.FILLMANID,
       AI.CONDITION,
       AI.PROCESSDEFNAME,
       AI.APPLYUNIT,
       H.TOPICPRODEFCHNAME,
       H.APPCATE,
       to_char(AI.CREATETIME,'yyyy-MM-dd hh24:mi:ss') as CREATETIME,
       to_char(AI.UPDATETIME,'yyyy-MM-dd hh24:mi:ss') as UPDATETIME,
       NULL AS APPCATENAME,
       NULL AS CONDITIONNAME,  
       
		y.handlerid,
		y.handlername,
		y.applyuserid,
		y.applyusername,
		y.applypost,
		y.applypid,
		y.applypname,
		y.applyorgid,
		y.applyorgname,
		y.applydegree1,
		y.applydegree1fzr,
		y.applydegree2,
		y.applydegree2fzr,
		y.applydegree3,
		y.applydegree3fzr,
		y.feegenuscostcenterid,
		y.feegenuscostcentername,
		y.contactinformation,
		y.bqq,
		y.projectbudget,
		y.starttype,
		y.transformgenuscostcenterid,
		y.transformgenuscostcentername,
		y.projecttype,
		y.expectstarttime,
		y.expectdeliverytime,
		y.lossmoney,
		y.applyreason,
		y.designrequirements,
		y.projectapplynumber,
		y.projectcost,
		y.suppliername,
		y.suppliertell,
		y.clearprojectcost,
		y.finemoney,
		y.warrantymoney,
		y.paritydesc,
		y.checkdesc,
		y.budgetmoney,
		y.contractcost,
		y.actualstarttime,
		y.actualendtime,
		y.checkapplytime,
		y.checkpasstime,
		y.clearamount,
		y.addfinemoney,
		y.checkclearamount,
		y.appno,
		y.xqbmastarttime,
		y.yyghzxendtime,
		y.cgswbstarttime,
		y.cgswbendtime,
		y.xmzjqdstarttime,
		y.xmzjqdendtime,
		y.gcxmglbstarttime,
		y.gcxmglbendtime,
		y.cwglbstarttime,
		y.cwglbendtime,
		y.days1,
		y.days2,
		y.days3,
		y.days4,
		y.days5,
		y.days
      
  FROM OA_APPLYINFO AI,
  (SELECT 
  		GCSQ.*,
		to_char(WI1.STARTTIME,'yyyy-MM-dd') AS XQBMASTARTTIME,
		to_char(WI2.ENDTIME,'yyyy-MM-dd') AS YYGHZXENDTIME,
		to_char(WI3.STARTTIME,'yyyy-MM-dd') AS CGSWBSTARTTIME,
		to_char(WI3.ENDTIME,'yyyy-MM-dd') AS CGSWBENDTIME,
		to_char(WI4.STARTTIME,'yyyy-MM-dd') AS XMZJQDSTARTTIME,
		to_char(WI4.ENDTIME,'yyyy-MM-dd') AS XMZJQDENDTIME,
		to_char(WI5.STARTTIME,'yyyy-MM-dd') AS GCXMGLBSTARTTIME,
		to_char(WI5.ENDTIME,'yyyy-MM-dd') AS GCXMGLBENDTIME,
		to_char(WI6.STARTTIME,'yyyy-MM-dd') AS CWGLBSTARTTIME,
		to_char(WI6.ENDTIME,'yyyy-MM-dd') AS CWGLBENDTIME,
		to_date(to_char(WI2.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI1.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') AS days1,
		to_date(to_char(WI3.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI3.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') AS days2,
		to_date(to_char(WI4.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI4.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') AS days3,
		to_date(to_char(WI5.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI5.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') AS days4,
		to_date(to_char(WI6.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI6.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') AS days5,
		to_date(to_char(WI2.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI1.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') +
		to_date(to_char(WI3.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI3.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') +
		to_date(to_char(WI4.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI4.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') +
		to_date(to_char(WI5.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI5.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') +
		to_date(to_char(WI6.ENDTIME,'yyyy-mm-dd'),'yyyy-mm-dd') - to_date(to_char(WI6.STARTTIME,'yyyy-mm-dd'),'yyyy-mm-dd') AS days
	FROM
  YD_YW_GCSQ GCSQ
  LEFT JOIN WFWORKITEM WI1
	ON GCSQ.PROCESSINSTID = WI1.PROCESSINSTID
	AND WI1.ACTIVITYDEFID = 'handler' 
LEFT JOIN WFWORKITEM WI2
  ON GCSQ.PROCESSINSTID = WI2.PROCESSINSTID
	AND WI2.ASSISTANT IS NOT NULL
	AND WI2.ACTIVITYDEFID = 'YD_ZB_YYGHBFZR' 
LEFT JOIN WFWORKITEM WI3
	ON GCSQ.PROCESSINSTID = WI3.PROCESSINSTID
	AND WI3.ASSISTANT IS NOT NULL 
	AND WI3.ACTIVITYDEFID = 'YD_ZB_CGZXSWZFZR' 
LEFT JOIN WFWORKITEM WI4
	ON GCSQ.PROCESSINSTID = WI4.PROCESSINSTID
	AND WI4.ASSISTANT IS NOT NULL 
	AND WI4.ACTIVITYDEFID = 'YD_ZZ_FZR4' 
LEFT JOIN WFWORKITEM WI5
	ON GCSQ.PROCESSINSTID = WI5.PROCESSINSTID
	AND WI5.ASSISTANT IS NOT NULL 
	AND WI5.ACTIVITYDEFID = 'YD_ZB_CGZXGCXMGLB'
LEFT JOIN WFWORKITEM WI6
	ON GCSQ.PROCESSINSTID = WI6.PROCESSINSTID
	AND WI6.ASSISTANT IS NOT NULL 
	AND WI6.ACTIVITYDEFID = 'YD_ZB_CWGLB_GCSHZ'
  )Y,YD_BPS_HLEPTOPIC H,OM_ORGANIZATION O
 WHERE AI.PROCESSDEFNAME='com.yd.soa.bpsyewumgr.gongchengshenqing.gcsq'
   AND AI.PROCESSDEFNAME = H.TOPICPRODEFNAME
   AND AI.APPLYNO=Y.APPNO
   AND AI.IFDELETED = 0
   AND AI.DEPARTMENTID = to_char(O.ORGID)
   
		 	  <isNotNull prepend="AND" property="filterid">
		          <![CDATA[EXISTS(SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 0
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND F.SCOPETYPEID = AI.APPLERID
        UNION
        SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 3
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND F.SCOPETYPEID=3
        UNION
        SELECT 1
          FROM YD_CF_FILTER F
         WHERE F.FILTERTYPE = 1
           AND F.IFDELETED = 0
           AND F.OPID = #filterid#
           AND F.SCOPETYPE = 2
           AND F.FILTERTYPEID = AI.PROCESSDEFNAME
           AND INSTR(O.ORGSEQ,'.'||F.SCOPETYPEID||'.')>0
       )]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="applyunit">
		          <![CDATA[INSTR(AI.APPLYUNIT,#applyunit#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="department">
		          <![CDATA[INSTR(AI.DEPARTMENT,#department#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="appler">
		          <![CDATA[INSTR(AI.APPLER,#appler#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="fillman">
		          <![CDATA[INSTR(AI.FILLMAN,#fillman#)>0]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="applerid">
		          AI.APPLERID ='$applerid$'
		      </isNotNull>
		 	  <isNotNull prepend="AND" property="processinstid">
		          AI.PROCESSINSTID = #processinstid#
		      </isNotNull>
		      
		      <isNotNull prepend="AND" property="startappdate">
		          <![CDATA[AI.APPDATE >= to_date('$startappdate$ 00:00:00', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="endappdate">
		      	  <![CDATA[AI.APPDATE < to_date('$endappdate$ 23:59:59', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      
		       <isNotNull prepend="AND" property="startupdatetime">
		          <![CDATA[AI.UPDATETIME >= to_date('$startupdatetime$ 00:00:00', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      <isNotNull prepend="AND" property="endupdatetime">
		      	  <![CDATA[AI.UPDATETIME < to_date('$endupdatetime$ 23:59:59', 'yyyy-MM-dd hh24:mi:ss')]]>
		      </isNotNull>
		      
		      <isNotNull prepend="AND" property="condition">
		          AI.CONDITION = #condition#
		      </isNotNull> ) S
		     order by S.CREATETIME desc
     </select>
</sqlMap>